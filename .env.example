# 沙海拾金本地配置示例
# 复制成 .env 后再填自己的 key。
# 这个文件只放空值，不放真实密钥。
# Treasure in the Desert Local Configuration Example
# Copy this file to `.env` and then fill in your own keys.
# This file should contain only empty values—do not store actual secret keys here.

# 基本路径和默认数据源
# Path and Default Data Source
DATA_CENTER_DB_PATH=Data_Center/Data.db
DEFAULT_PRICE_PROVIDER=alpha_vantage
DEFAULT_NEWS_PROVIDER=alpha_vantage

# LLM：后面做新闻摘要、策略讨论和代码 agent 会用到
# LLMs
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GROK_API_KEY=
GROK_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# 行情数据源
# 现在代码里接了 Alpha Vantage / Twelve Data / Finnhub / Polygon。
# 后面几家先留个位置，等需要的时候再补 provider。
# Market Data Sources
# The current codebase integrates Alpha Vantage, Twelve Data, Finnhub, and Polygon.
# Slots have been reserved for additional providers; these will be implemented later as needed.
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=
EODHD_API_KEY=
TIINGO_API_KEY=
MARKETSTACK_API_KEY=
STOOQ_API_KEY=

# 新闻数据源
# Alpha Vantage / Finnhub 可以复用行情 key，也可以单独填新闻 key。
# 其他几家先当备选，后面看新闻质量再决定接不接。
# News Data Sources
# For Alpha Vantage and Finnhub, you can either reuse your existing market data API key or provide a dedicated key specifically for news.
# The other providers will be kept as backups for now; we will decide whether to integrate them later, based on the quality of their news content.
ALPHA_VANTAGE_NEWS_API_KEY=
FINNHUB_NEWS_API_KEY=
MARKETAUX_API_KEY=
NEWSAPI_API_KEY=
STOCKNEWSAPI_API_KEY=
THENEWSAPI_API_KEY=
NEWSDATA_API_KEY=
FMP_NEWS_API_KEY=
EODHD_NEWS_API_KEY=
GNEWS_API_KEY=
